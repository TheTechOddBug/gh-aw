---
// @ts-ignore The docs app already uses this runtime package from Astro components.
import octicons from '@primer/octicons';
import {
	buildWorkshopFlow,
	workshopDefaults,
	workshopJourneys,
	workshopRoutes,
	workshopScenarios,
} from '../../lib/workshop/manifest';
import { workshopContent, workshopSource, type WorkshopContentEntry } from '../../generated/workshop-content.ts';

type WorkshopEntry = {
	id: string;
	title: string;
	summary: string;
	body: string;
};

type WorkshopStep = {
	key: string;
	file: string;
	title: string;
	summary: string;
	githubUrl: string;
	actions: string[];
	checks: string[];
	body: string;
};

const workshopGithubBase = workshopSource.githubBaseUrl;
const workshopImageBase = workshopSource.rawBaseUrl;
const primerIcons = octicons as Record<string, { toSVG: (options: Record<string, string | number>) => string }>;

function iconSvg(name: string, size = 20) {
	const icon = primerIcons[name] ?? primerIcons.workflow;
	return icon.toSVG({ width: size, height: size, 'aria-hidden': 'true' });
}

function escapeHtml(value: string) {
	return value
		.replace(/&/gu, '&amp;')
		.replace(/</gu, '&lt;')
		.replace(/>/gu, '&gt;')
		.replace(/"/gu, '&quot;')
		.replace(/'/gu, '&#39;');
}

function safeJson(value: unknown): string {
	return JSON.stringify(value)
		.replace(/</gu, '\\u003c')
		.replace(/>/gu, '\\u003e')
		.replace(/&/gu, '\\u0026');
}

function resolveWorkshopAssetUrl(value: string) {
	if (/^(?:https?:|mailto:|#|\/)/u.test(value)) return value;
	if (value.startsWith('images/')) return new URL(value, workshopImageBase).toString();
	return '#';
}

function renderInlineMarkdown(value: string) {
	return escapeHtml(value)
		.replace(/!\[([^\]]*)\]\(([^)]+)\)/gu, (_match, alt, src) => {
			return `<img src="${escapeHtml(resolveWorkshopAssetUrl(src))}" alt="${escapeHtml(alt)}" loading="lazy" />`;
		})
		.replace(/\[([^\]]+)\]\(([^)]+)\)/gu, (_match, text, href) => {
			const link = escapeHtml(resolveWorkshopAssetUrl(href));
			const localLink = href.endsWith('.md') || href.includes('.md#')
				? ` data-workshop-local-link="${escapeHtml(href)}"`
				: '';
			return `<a href="${link}"${localLink}>${text}</a>`;
		})
		.replace(/`([^`]+)`/gu, '<code>$1</code>')
		.replace(/\*\*([^*]+)\*\*/gu, '<strong>$1</strong>')
		.replace(/_([^_]+)_/gu, '<em>$1</em>');
}

function slugId(text: string) {
	return text
		.toLowerCase()
		.replace(/[^\w\s-]/gu, '')
		.replace(/[\s_]+/gu, '-')
		.replace(/^-+|-+$/gu, '');
}

function renderWorkshopMarkdown(markdown: string) {
	const lines = markdown.split('\n');
	const blocks: string[] = [];
	let paragraph: string[] = [];
	let list: string[] = [];
	let orderedList: string[] = [];
	let checklist: string[] = [];
	let tableRows: string[][] = [];
	let code: string[] = [];
	let codeLanguage = '';
	let inCode = false;
	let admonitionType = '';
	let admonitionLines: string[] = [];

	const flushParagraph = () => {
		if (paragraph.length === 0) return;
		blocks.push(`<p>${renderInlineMarkdown(paragraph.join(' '))}</p>`);
		paragraph = [];
	};

	const flushList = () => {
		if (list.length > 0) {
			blocks.push(`<ul>${list.map((item) => `<li>${renderInlineMarkdown(item)}</li>`).join('')}</ul>`);
			list = [];
		}
		if (orderedList.length > 0) {
			blocks.push(`<ol>${orderedList.map((item) => `<li>${renderInlineMarkdown(item)}</li>`).join('')}</ol>`);
			orderedList = [];
		}
		if (checklist.length > 0) {
			blocks.push(`<ul class="aw-workshop-checklist">${checklist.join('')}</ul>`);
			checklist = [];
		}
	};

	const flushTable = () => {
		if (tableRows.length === 0) return;
		const [header, , ...body] = tableRows;
		if (!header) { tableRows = []; return; }
		const th = header.map((cell) => `<th>${renderInlineMarkdown(cell)}</th>`).join('');
		const rows = body.map((row) => `<tr>${row.map((cell) => `<td>${renderInlineMarkdown(cell)}</td>`).join('')}</tr>`).join('');
		blocks.push(`<div class="aw-workshop-table-wrap"><table><thead><tr>${th}</tr></thead><tbody>${rows}</tbody></table></div>`);
		tableRows = [];
	};

	const flushAdmonition = () => {
		if (!admonitionType) return;
		const content = admonitionLines.join(' ');
		blocks.push(`<aside class="aw-workshop-admonition aw-workshop-admonition-${admonitionType.toLowerCase()}">${renderInlineMarkdown(content)}</aside>`);
		admonitionType = '';
		admonitionLines = [];
	};

	for (const line of lines) {
		if (line.startsWith('```')) {
			flushAdmonition();
			if (inCode) {
				blocks.push(`<pre><code class="language-${escapeHtml(codeLanguage)}">${escapeHtml(code.join('\n'))}</code></pre>`);
				code = [];
				codeLanguage = '';
				inCode = false;
			} else {
				flushParagraph();
				flushList();
				flushTable();
				codeLanguage = line.slice(3).trim();
				inCode = true;
			}
			continue;
		}

		if (inCode) {
			code.push(line);
			continue;
		}

		const trimmed = line.trim();
		if (!trimmed || trimmed === '---') {
			flushParagraph();
			flushList();
			flushTable();
			flushAdmonition();
			continue;
		}

		// GitHub-flavored admonitions: > [!TYPE]
		if (trimmed.startsWith('>')) {
			const admonitionMatch = trimmed.match(/^>\s*\[!(NOTE|TIP|IMPORTANT|WARNING|CAUTION)\]/iu);
			if (admonitionMatch) {
				flushParagraph();
				flushList();
				flushTable();
				flushAdmonition();
				admonitionType = admonitionMatch[1];
				admonitionLines = [];
				continue;
			}
			const continuationText = trimmed.replace(/^>\s?/u, '');
			if (admonitionType) {
				if (continuationText) admonitionLines.push(continuationText);
				continue;
			}
			flushParagraph();
			flushList();
			flushTable();
			blocks.push(`<aside>${renderInlineMarkdown(continuationText)}</aside>`);
			continue;
		}

		// Flush open admonition before non-blockquote lines
		if (admonitionType) flushAdmonition();

		// Tables: lines with pipes
		if (trimmed.startsWith('|')) {
			flushParagraph();
			flushList();
			const cells = trimmed.slice(1, -1).split('|').map((c) => c.trim());
			tableRows.push(cells);
			continue;
		}
		if (tableRows.length > 0) flushTable();

		const heading = trimmed.match(/^(#{1,4})\s+(.+)$/u);
		if (heading) {
			flushParagraph();
			flushList();
			const level = Math.min(heading[1].length + 1, 4);
			const id = slugId(heading[2].replace(/[*_`[\]]/gu, ''));
			blocks.push(`<h${level} id="${id}">${renderInlineMarkdown(heading[2])}</h${level}>`);
			continue;
		}

		const checklistItem = trimmed.match(/^- \[([ x])\]\s+(.+)$/iu);
		if (checklistItem) {
			flushParagraph();
			list = [];
			orderedList = [];
			const checked = checklistItem[1].toLowerCase() === 'x' ? ' checked' : '';
			checklist.push(`<li><label><input type="checkbox" disabled${checked} /> <span>${renderInlineMarkdown(checklistItem[2])}</span></label></li>`);
			continue;
		}

		const orderedItem = trimmed.match(/^\d+\.\s+(.+)$/u);
		if (orderedItem) {
			flushParagraph();
			checklist = [];
			list = [];
			orderedList.push(orderedItem[1]);
			continue;
		}

		const listItem = trimmed.match(/^-\s+(.+)$/u);
		if (listItem) {
			flushParagraph();
			checklist = [];
			orderedList = [];
			list.push(listItem[1]);
			continue;
		}

		paragraph.push(trimmed);
	}

	flushParagraph();
	flushList();
	flushTable();
	flushAdmonition();
	return blocks.join('');
}

function stripMarkdown(value: string) {
	return value
		.replace(/!\[([^\]]*)\]\([^)]+\)/gu, '$1')
		.replace(/\[([^\]]+)\]\([^)]+\)/gu, '$1')
		.replace(/`([^`]+)`/gu, '$1')
		.replace(/\*\*([^*]+)\*\*/gu, '$1')
		.replace(/_([^_]+)_/gu, '$1')
		.replace(/<[^>]+>/gu, '')
		.trim();
}

function uniqueItems(items: string[]) {
	const seen = new Set<string>();
	return items.filter((item) => {
		const normalized = item.toLowerCase();
		if (seen.has(normalized)) return false;
		seen.add(normalized);
		return true;
	});
}

function extractActionItems(markdown: string) {
	const lines = markdown.split('\n').map((line) => line.trim());
	const actions: string[] = [];
	let inCode = false;

	for (const line of lines) {
		if (line.startsWith('```')) {
			inCode = !inCode;
			continue;
		}
		if (inCode) continue;

		const action = line.match(/^\*\*Action:\*\*\s+(.+)$/u);
		if (action) actions.push(stripMarkdown(action[1]));

		const numbered = line.match(/^\d+\.\s+(.+)$/u);
		if (numbered) actions.push(stripMarkdown(numbered[1]));

		const checkbox = line.match(/^- \[[ x]\]\s+(.+)$/iu);
		if (checkbox) actions.push(stripMarkdown(checkbox[1]));
	}

	return uniqueItems(actions)
		.filter((item) => item.length > 0 && item.length < 180)
		.slice(0, 4);
}

function extractCheckpointItems(markdown: string) {
	const checkpoint = markdown.match(/##\s+✅\s+Checkpoint[\s\S]*?(?=\n##\s+|\n#\s+|$)/u)?.[0] ?? markdown;
	const checks = checkpoint
		.split('\n')
		.map((line) => line.trim().match(/^- \[[ x]\]\s+(.+)$/iu)?.[1])
		.filter((item): item is string => Boolean(item))
		.map(stripMarkdown);

	return uniqueItems(checks)
		.filter((item) => item.length > 0 && item.length < 180)
		.slice(0, 5);
}

function renderTutorialStep(step: WorkshopStep) {
	return renderWorkshopMarkdown(step.body);
}

function normalizeKey(value: string) {
	return value.replace(/\.md$/u, '');
}

const workshopEntries: WorkshopEntry[] = workshopContent.map((entry: WorkshopContentEntry) => ({
	id: entry.id,
	title: entry.title,
	summary: entry.summary,
	body: entry.body,
}));

const workshopSteps: WorkshopStep[] = workshopEntries.map((entry: WorkshopEntry) => {
	const key = normalizeKey(entry.id);

	return {
		key,
		file: `${key}.md`,
		title: entry.title,
		summary: entry.summary,
		githubUrl: new URL(`${key}.md`, workshopGithubBase).toString(),
		actions: extractActionItems(entry.body),
		checks: extractCheckpointItems(entry.body),
		body: entry.body,
	};
});

const initialFlow = buildWorkshopFlow(workshopDefaults.journeyId, workshopDefaults.scenarioId);
const initialStepKey = initialFlow[0] ?? workshopSteps[0]?.key ?? '';
const initialStep = workshopSteps.find((item) => item.key === initialStepKey) ?? workshopSteps[0];
---

<section
	class="aw-workshop"
	data-workshop-root
	data-image-base={workshopImageBase}
	data-initial-step={initialStepKey}
>
	<div class="aw-workshop-setup" data-workshop-setup>
		<div class="aw-workshop-setup-step" data-workshop-setup-step="workspace">
			<section class="aw-workshop-picker">
				<div class="aw-workshop-picker-header">
					<p class="aw-workshop-picker-kicker">Workspace</p>
					<h3>Where do you like to work?</h3>
					<p class="aw-workshop-picker-help">The guide stays here. Pick the workspace you will use beside it.</p>
				</div>
				<div class="aw-workshop-card-grid">
					{workshopJourneys.map((journey) => (
						<button
							type="button"
							class="aw-workshop-card"
							data-workshop-journey={journey.id}
							style={`--aw-workshop-card-accent: ${journey.accent};`}
						>
							<span class="aw-workshop-card-icon" set:html={iconSvg(journey.icon)} />
							<span class="aw-workshop-card-kicker">{journey.kicker}</span>
							<strong>{journey.label}</strong>
							<span>{journey.summary}</span>
						</button>
					))}
				</div>
			</section>
		</div>

		<div class="aw-workshop-setup-step" data-workshop-setup-step="scenario" hidden>
			<section class="aw-workshop-picker">
				<div class="aw-workshop-picker-header">
					<p class="aw-workshop-picker-kicker">Scenario</p>
					<h3>What do you want to automate?</h3>
				</div>
				<div class="aw-workshop-card-grid aw-workshop-card-grid-scenarios">
					{workshopScenarios.map((scenario) => (
						<button
							type="button"
							class="aw-workshop-card aw-workshop-card-scenario"
							data-workshop-scenario={scenario.id}
						>
							<span class="aw-workshop-card-icon" set:html={iconSvg(scenario.icon)} />
							<span class="aw-workshop-card-kicker">{scenario.kicker}</span>
							<strong>{scenario.label}</strong>
							<span>{scenario.summary}</span>
						</button>
					))}
				</div>
			</section>

			<section class="aw-workshop-tunnel-panel" data-workshop-tunnel-panel hidden>
				<div>
					<p class="aw-workshop-picker-kicker">Codespaces</p>
					<h3>GitHub Codespaces</h3>
					<p>
						This path uses a GitHub Codespace with VS Code. Open your repository in Codespaces and VS Code will start automatically in the browser or your desktop app.
					</p>
				</div>
				<div class="aw-workshop-tunnel-actions">
					<a href="https://docs.github.com/en/codespaces/overview" target="_blank" rel="noreferrer">Codespaces docs</a>
					<a href="https://github.com/codespaces" target="_blank" rel="noreferrer">Open Codespaces</a>
				</div>
			</section>

			<div class="aw-workshop-setup-nav aw-workshop-setup-nav-start">
				<button type="button" class="aw-workshop-inline-button" data-workshop-setup-back>
					Back
				</button>
			</div>
		</div>
	</div>

	<section class="aw-workshop-flow" data-workshop-tutorial hidden>
		<div class="aw-workshop-flow-header">
			<div>
				<p class="aw-workshop-picker-kicker">Guided run</p>
				<h3 data-workshop-flow-title>Step map</h3>
			</div>
		</div>

		<div class="aw-workshop-panel-shell">
			<div class="aw-workshop-panel-header">
				<div>
					<p class="aw-workshop-panel-meta" data-workshop-step-position>Step 1</p>
				</div>
			</div>

			<div class="aw-workshop-lesson-shell">
				<aside class="aw-workshop-lesson-rail" aria-label="Workshop progress">
					<div class="aw-workshop-lesson-progress">
						<span data-workshop-lesson-percent>0%</span>
						<div class="aw-workshop-progress-timeline">
							<div class="aw-workshop-progress-track"><span data-workshop-lesson-bar style={`width: ${initialFlow.length ? '0%' : '100%'};`} /></div>
							<div class="aw-workshop-step-bubbles" data-workshop-step-bubbles aria-label="Workshop steps">
								{initialFlow.map((stepKey, index) => {
									const step = workshopSteps.find((item) => item.key === stepKey);
									if (!step) return null;

									return (
										<button
											type="button"
											class="aw-workshop-step-bubble"
											data-workshop-step-link={step.key}
											title={`${index + 1}. ${step.title}`}
											aria-label={`Go to step ${index + 1}: ${step.title}`}
										/>
									);
								})}
							</div>
						</div>
					</div>
					<p data-workshop-lesson-context>Start with the welcome step, then follow the path selected above.</p>
					<button type="button" class="aw-workshop-rail-link" data-workshop-change>
						Change workspace or scenario
					</button>
				</aside>
				<article class="aw-workshop-step-content sl-markdown-content" data-workshop-step-content set:html={initialStep ? renderTutorialStep(initialStep) : ''} />
			</div>

			<div class="aw-workshop-panel-footer">
				<button type="button" class="aw-workshop-nav-button" data-workshop-prev>
					Previous step
				</button>
				<button type="button" class="aw-workshop-nav-button aw-workshop-nav-button-primary" data-workshop-next>
					Next step
				</button>
			</div>
		</div>
	</section>

	<script
		type="application/json"
		id="aw-workshop-step-data"
		set:html={safeJson(workshopSteps.map((step) => ({
			key: step.key,
			file: step.file,
			title: step.title,
			summary: step.summary,
			githubUrl: step.githubUrl,
			actions: step.actions,
			checks: step.checks,
			body: step.body,
		})))}
	/>
	<script
		type="application/json"
		id="aw-workshop-manifest"
		set:html={safeJson({
			defaults: workshopDefaults,
			journeys: workshopJourneys,
			routes: workshopRoutes,
			scenarios: workshopScenarios,
		})}
	/>
	<script is:inline>
		const root = document.querySelector('[data-workshop-root]');
		const stepDataNode = document.getElementById('aw-workshop-step-data');
		const manifestNode = document.getElementById('aw-workshop-manifest');

		if (root && stepDataNode && manifestNode) {
			const steps = JSON.parse(stepDataNode.textContent || '[]');
			const manifest = JSON.parse(manifestNode.textContent || '{}');
			const storageKey = 'gh-aw-docs-workshop-state';
			const stepMap = new Map(steps.map((step) => [step.key, step]));
			const allStepKeys = steps.map((step) => step.key);
			const initialStep = root.getAttribute('data-initial-step') || steps[0]?.key || '';

			const buildFlow = (journeyId, scenarioId) => {
				const journey = manifest.journeys.find((item) => item.id === journeyId) || manifest.journeys[0];
				const scenario = manifest.scenarios.find((item) => item.id === scenarioId) || manifest.scenarios[0];
				const journeyRoute = manifest.routes.workspaces[journey.id];
				const scenarioRoute = manifest.routes.scenarios[scenario.id];
				const ordered = [
					...journeyRoute.prelude,
					scenarioRoute.designStep,
					scenarioRoute.buildStepByWorkspace[journey.id],
					...journeyRoute.postBuild,
					...(manifest.routes.preSchedule || []),
					journeyRoute.scheduleStep,
					...manifest.routes.wrapUp,
				];

				return [...new Set(ordered)].filter((stepKey) => stepMap.has(stepKey));
			};

			const readState = () => {
				try {
					const parsed = JSON.parse(localStorage.getItem(storageKey) || '{}');
					return {
						journeyId: parsed.journeyId || manifest.defaults.journeyId,
						scenarioId: parsed.scenarioId || manifest.defaults.scenarioId,
						stepKey: parsed.stepKey || initialStep,
					};
				} catch {
					return {
						journeyId: manifest.defaults.journeyId,
						scenarioId: manifest.defaults.scenarioId,
						stepKey: initialStep,
					};
				}
			};

			const state = readState();

			const saveState = () => {
				localStorage.setItem(storageKey, JSON.stringify(state));
			};

			const track = (name, detail) => {
				window.dispatchEvent(new CustomEvent('gh-aw-workshop-analytics', { detail: { name, ...detail } }));
				if (typeof window.plausible === 'function') {
					window.plausible(name, { props: detail });
				}
			};

			const escapeHtml = (value) => String(value)
				.replace(/&/gu, '&amp;')
				.replace(/</gu, '&lt;')
				.replace(/>/gu, '&gt;')
				.replace(/"/gu, '&quot;')
				.replace(/'/gu, '&#39;');

			const resolveWorkshopAssetUrl = (value) => {
				if (/^(?:https?:|mailto:|#|\/)/u.test(value)) return value;
				if (value.startsWith('images/')) {
					const resolved = new URL(value, root.dataset.imageBase || window.location.href).toString();
					return /^https?:/u.test(resolved) ? resolved : '#';
				}
				return '#';
			};

			const renderInlineMarkdown = (value) => escapeHtml(value)
				.replace(/!\[([^\]]*)\]\(([^)]+)\)/gu, (_match, alt, src) => {
					return `<img src="${escapeHtml(resolveWorkshopAssetUrl(src))}" alt="${escapeHtml(alt)}" loading="lazy" />`;
				})
				.replace(/\[([^\]]+)\]\(([^)]+)\)/gu, (_match, text, href) => {
					const link = escapeHtml(resolveWorkshopAssetUrl(href));
					const localLink = href.endsWith('.md') || href.includes('.md#')
						? ` data-workshop-local-link="${escapeHtml(href)}"`
						: '';
					return `<a href="${link}"${localLink}>${text}</a>`;
				})
				.replace(/`([^`]+)`/gu, '<code>$1</code>')
				.replace(/\*\*([^*]+)\*\*/gu, '<strong>$1</strong>')
				.replace(/_([^_]+)_/gu, '<em>$1</em>');

			const stripMarkdown = (value) => String(value)
				.replace(/!\[([^\]]*)\]\([^)]+\)/gu, '$1')
				.replace(/\[([^\]]+)\]\([^)]+\)/gu, '$1')
				.replace(/`([^`]+)`/gu, '$1')
				.replace(/\*\*([^*]+)\*\*/gu, '$1')
				.replace(/_([^_]+)_/gu, '$1')
				.replace(/<[^>]+>/gu, '')
				.trim();

			const slugId = (text) => text
				.toLowerCase()
				.replace(/[^\w\s-]/gu, '')
				.replace(/[\s_]+/gu, '-')
				.replace(/^-+|-+$/gu, '');

			const renderStepBody = (body) => {
				const lines = String(body || '').split('\n');
				const blocks = [];
				let paragraph = [];
				let list = [];
				let orderedList = [];
				let checklist = [];
				let tableRows = [];
				let code = [];
				let codeLanguage = '';
				let inCode = false;
				let admonitionType = '';
				let admonitionLines = [];

				const flushParagraph = () => {
					if (paragraph.length === 0) return;
					blocks.push(`<p>${renderInlineMarkdown(paragraph.join(' '))}</p>`);
					paragraph = [];
				};

				const flushList = () => {
					if (list.length > 0) {
						blocks.push(`<ul>${list.map((item) => `<li>${renderInlineMarkdown(item)}</li>`).join('')}</ul>`);
						list = [];
					}
					if (orderedList.length > 0) {
						blocks.push(`<ol>${orderedList.map((item) => `<li>${renderInlineMarkdown(item)}</li>`).join('')}</ol>`);
						orderedList = [];
					}
					if (checklist.length > 0) {
						blocks.push(`<ul class="aw-workshop-checklist">${checklist.join('')}</ul>`);
						checklist = [];
					}
				};

				const flushTable = () => {
					if (tableRows.length === 0) return;
					const [header, , ...body] = tableRows;
					if (!header) { tableRows = []; return; }
					const th = header.map((cell) => `<th>${renderInlineMarkdown(cell)}</th>`).join('');
					const rows = body.map((row) => `<tr>${row.map((cell) => `<td>${renderInlineMarkdown(cell)}</td>`).join('')}</tr>`).join('');
					blocks.push(`<div class="aw-workshop-table-wrap"><table><thead><tr>${th}</tr></thead><tbody>${rows}</tbody></table></div>`);
					tableRows = [];
				};

				const flushAdmonition = () => {
					if (!admonitionType) return;
					const content = admonitionLines.join(' ');
					blocks.push(`<aside class="aw-workshop-admonition aw-workshop-admonition-${admonitionType.toLowerCase()}">${renderInlineMarkdown(content)}</aside>`);
					admonitionType = '';
					admonitionLines = [];
				};

				for (const line of lines) {
					if (line.startsWith('```')) {
						flushAdmonition();
						if (inCode) {
							blocks.push(`<pre><code class="language-${escapeHtml(codeLanguage)}">${escapeHtml(code.join('\n'))}</code></pre>`);
							code = [];
							codeLanguage = '';
							inCode = false;
						} else {
							flushParagraph();
							flushList();
							flushTable();
							codeLanguage = line.slice(3).trim();
							inCode = true;
						}
						continue;
					}

					if (inCode) {
						code.push(line);
						continue;
					}

					const trimmed = line.trim();
					if (!trimmed || trimmed === '---') {
						flushParagraph();
						flushList();
						flushTable();
						flushAdmonition();
						continue;
					}

					// GitHub-flavored admonitions: > [!TYPE]
					if (trimmed.startsWith('>')) {
						const admonitionMatch = trimmed.match(/^>\s*\[!(NOTE|TIP|IMPORTANT|WARNING|CAUTION)\]/iu);
						if (admonitionMatch) {
							flushParagraph();
							flushList();
							flushTable();
							flushAdmonition();
							admonitionType = admonitionMatch[1];
							admonitionLines = [];
							continue;
						}
						const continuationText = trimmed.replace(/^>\s?/u, '');
						if (admonitionType) {
							if (continuationText) admonitionLines.push(continuationText);
							continue;
						}
						flushParagraph();
						flushList();
						flushTable();
						blocks.push(`<aside>${renderInlineMarkdown(continuationText)}</aside>`);
						continue;
					}

					// Flush open admonition before non-blockquote lines
					if (admonitionType) flushAdmonition();

					// Tables: lines with pipes
					if (trimmed.startsWith('|')) {
						flushParagraph();
						flushList();
						const cells = trimmed.slice(1, -1).split('|').map((c) => c.trim());
						tableRows.push(cells);
						continue;
					}
					if (tableRows.length > 0) flushTable();

					const heading = trimmed.match(/^(#{1,4})\s+(.+)$/u);
					if (heading) {
						flushParagraph();
						flushList();
						const level = Math.min(heading[1].length + 1, 4);
						const id = slugId(heading[2].replace(/[*_`[\]]/gu, ''));
						blocks.push(`<h${level} id="${id}">${renderInlineMarkdown(heading[2])}</h${level}>`);
						continue;
					}

					const checklistItem = trimmed.match(/^- \[([ x])\]\s+(.+)$/iu);
					if (checklistItem) {
						flushParagraph();
						list = [];
						orderedList = [];
						const checked = checklistItem[1].toLowerCase() === 'x' ? ' checked' : '';
						checklist.push(`<li><label><input type="checkbox" disabled${checked} /> <span>${renderInlineMarkdown(checklistItem[2])}</span></label></li>`);
						continue;
					}

					const orderedItem = trimmed.match(/^\d+\.\s+(.+)$/u);
					if (orderedItem) {
						flushParagraph();
						checklist = [];
						list = [];
						orderedList.push(orderedItem[1]);
						continue;
					}

					const listItem = trimmed.match(/^-\s+(.+)$/u);
					if (listItem) {
						flushParagraph();
						checklist = [];
						orderedList = [];
						list.push(listItem[1]);
						continue;
					}

					paragraph.push(trimmed);
				}

				flushParagraph();
				flushList();
				flushTable();
				flushAdmonition();
				return blocks.join('');
			};

			const renderTutorialStep = (step) => {
				return renderStepBody(step.body || '');
			};

			const calculateProgressPercent = (stepIndex, flowLength) => {
				if (stepIndex < 0) return 0;
				if (flowLength <= 1) return 100;
				return Math.round((stepIndex / (flowLength - 1)) * 100);
			};

			const setupScreen = root.querySelector('[data-workshop-setup]');
			const setupSteps = root.querySelectorAll('[data-workshop-setup-step]');
			const tutorialScreen = root.querySelector('[data-workshop-tutorial]');
			const tunnelPanel = root.querySelector('[data-workshop-tunnel-panel]');
			const flowTitle = root.querySelector('[data-workshop-flow-title]');
			const stepPosition = root.querySelector('[data-workshop-step-position]');
			const prevButton = root.querySelector('[data-workshop-prev]');
			const nextButton = root.querySelector('[data-workshop-next]');
			const stepBodyContainer = root.querySelector('[data-workshop-step-content]');
			const lessonPercent = root.querySelector('[data-workshop-lesson-percent]');
			const lessonBar = root.querySelector('[data-workshop-lesson-bar]');
			const lessonContext = root.querySelector('[data-workshop-lesson-context]');
			const stepBubbles = root.querySelector('[data-workshop-step-bubbles]');
			let setupStep = 'workspace';

			const showSetupStep = (stepName) => {
				setupStep = stepName === 'scenario' ? 'scenario' : 'workspace';
				setupSteps.forEach((step) => {
					step.hidden = step.getAttribute('data-workshop-setup-step') !== setupStep;
				});
				render();
			};

			const showSetup = () => {
				setupScreen.hidden = false;
				tutorialScreen.hidden = true;
				root.classList.remove('is-tutorial-active');
				showSetupStep('workspace');
				root.scrollIntoView({ behavior: 'smooth', block: 'start' });
			};

			const showTutorial = () => {
				ensureCurrentStepIsVisible();
				render();
				setupScreen.hidden = true;
				tutorialScreen.hidden = false;
				root.classList.add('is-tutorial-active');
				root.scrollIntoView({ behavior: 'smooth', block: 'start' });
				track('Workshop Started', { journey: state.journeyId, scenario: state.scenarioId });
			};

			const getFlow = () => buildFlow(state.journeyId, state.scenarioId);

			const getFallbackStepKey = (flow = getFlow()) => {
				return flow[0] || initialStep || allStepKeys[0] || '';
			};

			const ensureCurrentStepIsVisible = () => {
				const flow = getFlow();
				if (!flow.includes(state.stepKey)) {
					state.stepKey = getFallbackStepKey(flow);
				}
			};

			const setCurrentStep = (stepKey, options = {}) => {
				if (typeof stepKey !== 'string' || !stepMap.has(stepKey)) return;
				state.stepKey = stepKey;
				saveState();
				render();
				if (!options.silent) {
					track('Workshop Step Viewed', {
						journey: state.journeyId,
						scenario: state.scenarioId,
						step: stepKey,
					});
				}
			};

			const setJourney = (journeyId) => {
				if (typeof journeyId !== 'string') return;
				state.journeyId = journeyId;
				ensureCurrentStepIsVisible();
				saveState();
				render();
				track('Workshop Journey Selected', { journey: journeyId, scenario: state.scenarioId });
			};

			const setScenario = (scenarioId) => {
				if (typeof scenarioId !== 'string') return;
				state.scenarioId = scenarioId;
				ensureCurrentStepIsVisible();
				saveState();
				render();
				track('Workshop Scenario Selected', { journey: state.journeyId, scenario: scenarioId });
			};

			const navigate = (direction) => {
				const flow = getFlow();
				if (flow.length === 0) return;
				const index = flow.indexOf(state.stepKey);
				const nextIndex = direction === 'next' ? index + 1 : index - 1;
				const target = flow[nextIndex];
				if (target) {
					setCurrentStep(target);
				} else {
					saveState();
					render();
				}
				root.scrollIntoView({ behavior: 'smooth', block: 'start' });
			};

			const render = () => {
				const flow = getFlow();
				const fallbackStepKey = getFallbackStepKey(flow);
				const activeStepKey = typeof state.stepKey === 'string' && stepMap.has(state.stepKey)
					? state.stepKey
					: fallbackStepKey;
				const activeStep = activeStepKey ? stepMap.get(activeStepKey) : undefined;
				if (!activeStep || !activeStepKey) {
					return;
				}

				state.stepKey = activeStepKey;
				const visibleFlow = flow.length > 0 ? flow : [activeStepKey];
				const journey = manifest.journeys.find((item) => item.id === state.journeyId) || manifest.journeys[0];
				const scenario = manifest.scenarios.find((item) => item.id === state.scenarioId) || manifest.scenarios[0];
				const stepIndex = visibleFlow.indexOf(activeStep.key);
				const progressPercent = calculateProgressPercent(stepIndex, visibleFlow.length);
				if (tunnelPanel) {
					tunnelPanel.hidden = state.journeyId !== 'vscode' || setupStep !== 'scenario';
				}
				lessonPercent.textContent = `${progressPercent}%`;
				lessonBar.style.width = `${progressPercent}%`;
				lessonContext.textContent = stepIndex >= 0
					? `${stepIndex + 1} of ${visibleFlow.length} in this ${journey.label.toLowerCase()} run.`
					: 'Linked step from the workshop source.';
				flowTitle.textContent = `${journey.label} x ${scenario.label}`;
				stepPosition.textContent = stepIndex >= 0 ? `Step ${stepIndex + 1} of ${visibleFlow.length}` : 'Linked step';
				stepBodyContainer.innerHTML = renderTutorialStep(activeStep);

				root.querySelectorAll('[data-workshop-journey]').forEach((button) => {
					const isActive = button.getAttribute('data-workshop-journey') === state.journeyId;
					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});

				root.querySelectorAll('[data-workshop-scenario]').forEach((button) => {
					const isActive = button.getAttribute('data-workshop-scenario') === state.scenarioId;
					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});

				if (stepBubbles) {
					stepBubbles.innerHTML = '';
					visibleFlow.forEach((stepKey, index) => {
						const step = stepMap.get(stepKey);
						if (!step) return;

						const button = document.createElement('button');
						button.type = 'button';
						button.className = 'aw-workshop-step-bubble';
						button.dataset.workshopStepLink = step.key;
						button.title = `${index + 1}. ${step.title}`;
						button.setAttribute('aria-label', `Go to step ${index + 1}: ${step.title}`);
						button.classList.toggle('is-complete', stepIndex > index);
						button.classList.toggle('is-active', step.key === activeStep.key);
						stepBubbles.appendChild(button);
					});
				}

				const flowIndex = visibleFlow.indexOf(activeStep.key);
				const isLastStep = flowIndex >= 0 && flowIndex >= visibleFlow.length - 1;
				prevButton.disabled = flowIndex <= 0;
				nextButton.disabled = flowIndex < 0;
				nextButton.textContent = isLastStep ? 'Finish workshop' : 'Next step';
			};

			root.addEventListener('click', (event) => {
				const target = event.target instanceof Element ? event.target.closest('button, a') : null;
				if (!target) return;

				if (target.matches('[data-workshop-change]')) {
					showSetup();
					return;
				}

				if (target.matches('[data-workshop-journey]')) {
					setJourney(target.getAttribute('data-workshop-journey'));
					showSetupStep('scenario');
					root.scrollIntoView({ behavior: 'smooth', block: 'start' });
					return;
				}

				if (target.matches('[data-workshop-scenario]')) {
					setScenario(target.getAttribute('data-workshop-scenario'));
					showTutorial();
					return;
				}

				if (target.matches('[data-workshop-setup-back]')) {
					showSetupStep('workspace');
					root.scrollIntoView({ behavior: 'smooth', block: 'start' });
					return;
				}

				if (target.matches('[data-workshop-step-link]')) {
					setCurrentStep(target.getAttribute('data-workshop-step-link'));
					return;
				}

				if (target.matches('[data-workshop-prev]')) {
					navigate('prev');
					return;
				}

				if (target.matches('[data-workshop-next]')) {
					navigate('next');
					return;
				}

				if (target.matches('[data-workshop-local-link]')) {
					event.preventDefault();
					const localHref = target.getAttribute('data-workshop-local-link') || '';
					const [filePart, anchorPart] = localHref.split('#');
					const stepKey = filePart.replace(/\.md$/u, '');
					setCurrentStep(stepKey);
					if (anchorPart) {
						requestAnimationFrame(() => {
							root.querySelector(`#${CSS.escape(anchorPart)}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
						});
						return;
					}
					root.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			});

			ensureCurrentStepIsVisible();
			render();
			showSetup();
		}
	</script>
</section>

